# ── Flask ──────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=phishing_detector
MONGO_COLLECTION_PHISHING=phishing_urls
MONGO_TIMEOUT_MS=5000

# ── ONNX model ─────────────────────────────────────────────────────────────────
ONNX_MODEL_PATH=../phase1-model/outputs/models/phishing_detector_quantized.onnx
CONFIDENCE_THRESHOLD=0.75

# ── VirusTotal ─────────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here
VIRUSTOTAL_TIMEOUT_SEC=10

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
WORKERS=4
